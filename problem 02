abstract class Payment {

    protected String transactionId;
    private static int counter = 1;

    Payment() {
        transactionId = generateTransactionId();
    }

    // Shared Transaction ID Generator
    protected String generateTransactionId() {
        return "TXN-" + System.currentTimeMillis() + "-" + (counter++);
    }

    // Shared Validation Logic
    protected void validateAccountDetails() {
        System.out.println("Validating account details...");
    }

    // Abstract Methods
    abstract void authorize(double amount);

    abstract void processPayment(double amount);

    abstract String generateReceipt();
}

// Optional Capabilities
interface Refundable {
    void refund(double amount);
}

interface RecurringBillable {
    void setupRecurring(double amount);
}

interface LoyaltyPointsEarner {
    void earnPoints(int points);
}

// Credit Card Payment
class CreditCardPayment extends Payment
        implements Refundable, RecurringBillable, LoyaltyPointsEarner {

    @Override
    void authorize(double amount) {
        System.out.println("Credit Card authorized for $" + amount);
    }

    @Override
    void processPayment(double amount) {
        validateAccountDetails();
        System.out.println("Credit Card payment processed: $" + amount);
    }

    @Override
    String generateReceipt() {
        return "Receipt: Credit Card | Transaction ID: " + transactionId;
    }

    @Override
    public void refund(double amount) {
        System.out.println("Refunded $" + amount + " to Credit Card");
    }

    @Override
    public void setupRecurring(double amount) {
        System.out.println("Recurring Credit Card payment set: $" + amount);
    }

    @Override
    public void earnPoints(int points) {
        System.out.println(points + " loyalty points earned.");
    }
}

